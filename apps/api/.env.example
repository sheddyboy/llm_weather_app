# ---------------------------------------------------------------------------
# Weather App API: environment template
# Copy to `.env` (gitignored) and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- Database (local Postgres now; same vars used for Docker later) ---
# Dev database and the dedicated test schema (see ARCHITECTURE §9).
DATABASE_URL=postgresql+asyncpg://postgres@localhost:5432/weatherapp
DATABASE_URL_TEST=postgresql+asyncpg://postgres@localhost:5432/weatherapp_test

# --- Cache ---
# Backend selector: `memory` (cachetools, local dev) or `redis` (deployment).
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0

# --- OpenWeatherMap (required) ---
# Free Access APIs: current weather, 5-day forecast, geocoding, air pollution.
OPENWEATHER_API_KEY=

# --- OpenAI (required for the LLM briefing) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- YouTube Data API v3 ---
# Used by the /records/{id}/media enrichment.
YOUTUBE_API_KEY=
# Safety toggle. Default `true` (key is available, calls run for real).
# Set to `false` to stop all live YouTube calls and return a clearly labeled
# stub response instead; use this if the 10,000 units/day quota is exhausted
# (one search costs 100 units). No code changes needed to flip it.
ENABLE_YOUTUBE=true

# --- Google Places API ---
# Used by the /records/{id}/media enrichment.
GOOGLE_PLACES_API_KEY=
# Safety toggle. Default `true` (key is available, calls run for real).
# Set to `false` to stop all live Places calls and return a clearly labeled
# stub response instead; use this if billing isn't configured or a SKU's
# free monthly cap is hit. /media still degrades gracefully on live errors.
ENABLE_PLACES=true

# --- Logging ---
LOG_LEVEL=INFO

# --- /meta endpoint (consumed by the frontend footer) ---
META_NAME=Weather App
META_DESCRIPTION=PM Accelerator, see https://www.linkedin.com/school/pmaccelerator/
